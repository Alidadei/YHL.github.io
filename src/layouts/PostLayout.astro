---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

interface Props {
  title: string;
  description?: string;
  date?: Date;
  tags?: string[];
  image?: string;
}

const { title, description, date, tags = [], image } = Astro.props;
---

<BaseLayout title={title} description={description} image={image}>
  <Header />
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 fade-in">
    <header class="mb-8">
      <h1 class="text-3xl font-bold text-primary mb-4">{title}</h1>
      {date && (
        <time datetime={date.toISOString()} class="text-text-muted text-sm">
          {date.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
        </time>
      )}
      {tags.length > 0 && (
        <div class="flex gap-2 mt-3">
          {tags.map((tag) => (
            <span class="px-2 py-1 text-xs rounded bg-bg-tertiary text-text-secondary">{tag}</span>
          ))}
        </div>
      )}
    </header>
    <div class="prose prose-lg max-w-none prose-headings:text-primary prose-a:text-accent">
      <slot />
    </div>
  </article>
  <Footer />
</BaseLayout>
