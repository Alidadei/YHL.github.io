---
import PageLayout from '../../layouts/PageLayout.astro';
import { type Lang } from '../../data/site';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };

const allTalks = await getCollection('talks');
const talks = allTalks.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<PageLayout title={lang === 'zh' ? '演讲与报告' : 'Talks'}>
  <h1 class="text-3xl font-bold text-primary mb-8">{lang === 'zh' ? '演讲与报告' : 'Talks & Presentations'}</h1>

  {talks.length === 0 ? (
    <p class="text-text-muted">{lang === 'zh' ? '暂无演讲' : 'No talks yet.'}</p>
  ) : (
    <div class="relative border-l-2 border-accent/30 ml-4 space-y-8">
      {talks.map((talk) => (
        <div class="relative pl-8">
          <div class="absolute -left-2 top-1 w-4 h-4 rounded-full bg-accent border-2 border-bg"></div>
          <div class="p-5 rounded-lg border border-border hover:border-accent/30 transition-all">
            <div class="flex items-start justify-between flex-wrap gap-2 mb-2">
              <h3 class="font-semibold text-primary">{talk.data.title}</h3>
              <span class="px-2 py-0.5 text-xs rounded bg-accent/10 text-accent">{talk.data.type}</span>
            </div>
            <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-text-muted">
              {talk.data.venue && <span>{talk.data.venue}</span>}
              {talk.data.location && <span>{talk.data.location}</span>}
              <time>{talk.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            </div>
            {talk.data.talkurl && (
              <a href={talk.data.talkurl} target="_blank" rel="noopener noreferrer" class="text-sm text-accent hover:text-accent-light mt-2 inline-block">
                {lang === 'zh' ? '查看详情' : 'View details'} &rarr;
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  )}
</PageLayout>
