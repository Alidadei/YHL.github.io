---
import PageLayout from '../../layouts/PageLayout.astro';
import { type Lang } from '../../data/site';
import { getCollection } from 'astro:content';

export function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params as { lang: Lang };

const allPubs = await getCollection('publications');
const pubs = allPubs.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Group by category
const categories: Record<string, string> = {
  manuscripts: lang === 'zh' ? '期刊论文' : 'Journal Articles',
  conferences: lang === 'zh' ? '会议论文' : 'Conference Papers',
  books: lang === 'zh' ? '书籍' : 'Books',
};

const grouped = Object.entries(categories).map(([key, label]) => ({
  key,
  label,
  items: pubs.filter((p) => p.data.category === key),
})).filter((g) => g.items.length > 0);
---

<PageLayout title={lang === 'zh' ? '论文发表' : 'Publications'}>
  <h1 class="text-3xl font-bold text-primary mb-8">{lang === 'zh' ? '论文发表' : 'Publications'}</h1>

  {grouped.length === 0 ? (
    <p class="text-text-muted">{lang === 'zh' ? '暂无论文' : 'No publications yet.'}</p>
  ) : (
    <div class="space-y-10">
      {grouped.map((group) => (
        <section>
          <h2 class="text-xl font-bold text-primary mb-4">{group.label}</h2>
          <div class="space-y-4">
            {group.items.map((pub) => (
              <div class="p-5 rounded-lg border border-border hover:border-accent/30 transition-all">
                <h3 class="font-semibold text-primary mb-1">{pub.data.title}</h3>
                {pub.data.venue && (
                  <p class="text-sm text-accent mb-2">{pub.data.venue}</p>
                )}
                {pub.data.excerpt && (
                  <p class="text-text-muted text-sm mb-3">{pub.data.excerpt}</p>
                )}
                <div class="flex gap-4 text-sm">
                  {pub.data.paperurl && (
                    <a href={pub.data.paperurl} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-light">
                      {lang === 'zh' ? '论文 PDF' : 'Paper PDF'} &darr;
                    </a>
                  )}
                  {pub.data.slidesurl && (
                    <a href={pub.data.slidesurl} target="_blank" rel="noopener noreferrer" class="text-accent hover:text-accent-light">
                      {lang === 'zh' ? 'Slides' : 'Slides'} &darr;
                    </a>
                  )}
                </div>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>
  )}
</PageLayout>
